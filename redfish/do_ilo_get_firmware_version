#!/usr/bin/env bash

set -o pipefail


do_ilo_get_firmware_version () {
  local user="$1";
  local pass="$2";
  local host="$3";

  curl -s --insecure -u ${user}:${pass} --max-time 30 --connect-timeout 10 -X GET \
  --header 'Content-Type: application/json' \
  --location "https://${host}/redfish/v1/Managers/1/" | \
  jq '.FirmwareVersion';
  
  if [[ $? -ne 0 ]] ; then
    echo "timeout";
  fi
}

if [[ $# -lt 3 ]]; then
  echo "usage: $0 user pass hostname";
  exit 0;
else
  do_ilo_get_firmware_version "$@";
fi

